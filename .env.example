# Example environment variables for local development and CI
# Copy this file to `.env` and fill in values appropriate for your setup.

# -----------------------------
# Core service settings
# -----------------------------
ML_ENGINE_URL=http://localhost:8001
ML_ENGINE_KEY=replace-me-with-a-secure-random-string

# Admin / service authentication (keep secret in production)
ADMIN_TOKEN=replace-me-admin-token
ADMIN_JWT_SECRET=replace-me-for-hs256-tests
ADMIN_JWKS_URL=
ADMIN_JWKS_AUDIENCE=
ADMIN_JWKS_CACHE_TTL=300

# -----------------------------
# Database / Supabase (optional)
# -----------------------------
# Example local DB URL (used by scripts and tests). In CI, prefer repository
# secrets and service containers instead of publishing credentials.
DATABASE_URL=postgresql://admin:password@localhost:5433/dellmology
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------
# Telegram notifier
# -----------------------------
# For production set `TELEGRAM_BOT_TOKEN` and `TELEGRAM_CHAT_ID` as secrets.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional: override API base for local E2E mock server
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_LOCAL_WEBHOOK=http://localhost:3001/webhook

# -----------------------------
# Scheduler settings
# -----------------------------
RETRAIN_SCHEDULE=daily
RETRAIN_HOUR=22
RETRAIN_DAY=sun
RETRAIN_CRON=

# -----------------------------
# Frontend / Next.js settings
# -----------------------------
NEXT_PUBLIC_STREAMER_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_TOKEN=replace-me-public-token

# -----------------------------
# Logging and debug
# -----------------------------
LOG_LEVEL=INFO
DEBUG_MODE=false

# -----------------------------
# CI / deployment placeholders
# Set these as GitHub repository secrets for CI and deployment
# -----------------------------
# Examples of GitHub secret names used by workflows (see CI_SECRETS.md):
# - TELEGRAM_BOT_TOKEN
# - TELEGRAM_CHAT_ID
# - SUPABASE_SERVICE_ROLE_KEY
# - WEB_ADMIN_KEY
# - SNAPSHOT_ADMIN_KEY
# - MODEL_METRICS_ADMIN_KEY
WEB_DEPLOY_URL=
WEB_ADMIN_KEY=

# -----------------------------
# Notes
# -----------------------------
# - Do NOT commit real secrets into the repository. Use `.env` locally and
#   GitHub repository secrets for CI workflows.
# - `TELEGRAM_BOT_TOKEN` and `TELEGRAM_CHAT_ID` are required only when
#   running the live Telegram notifier. For local E2E tests use
#   `TELEGRAM_API_BASE` to point at a mock server.


