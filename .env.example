# Example environment variables for IDX_Analyst
# Copy this to .env or set as repository secrets for CI/deploy

# Supabase/Postgres (optional - used if you want DB persistence)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

# Snapshot and metrics admin keys (used by API endpoints)
# Keep these secret in production and set them as GitHub secrets
SNAPSHOT_ADMIN_KEY=change-me-snapshot-key
MODEL_METRICS_ADMIN_KEY=change-me-model-metrics-key

# Optional: Dashboard upload from CI (set in GitHub Actions secrets)
WEB_ADMIN_KEY=change-me-web-admin-key
WEB_DEPLOY_URL=https://your-deployed-web-app.example

# Telegram (for production) OR use TELEGRAM_LOCAL_WEBHOOK for local E2E testing
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_LOCAL_WEBHOOK=http://localhost:3001/webhook
# Environment Configuration for Dellmology Pro
# Copy this file to .env and fill in your values

# === GEMINI AI ===
GEMINI_API_KEY=your_gemini_api_key_here

# === DATABASE ===
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=dellmology
DATABASE_URL=postgresql://admin:password@localhost:5433/dellmology?sslmode=disable

# === STOCKBIT ===
STOCKBIT_TOKEN=your_stockbit_token_here

# === TELEGRAM NOTIFICATIONS ===
# Create bot with @BotFather, then get token and chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === ML ENGINE ===
ML_ENGINE_URL=http://localhost:8001          # URL where the local Go/Python engine listens
ML_ENGINE_KEY=development_key_change_in_production  # shared secret used by frontend/backend

# === MODEL RETRAINING SCHEDULER ===
# Schedule type: 'daily' (at RETRAIN_HOUR), 'weekly' (on RETRAIN_DAY at RETRAIN_HOUR), or 'cron' (custom RETRAIN_CRON)
RETRAIN_SCHEDULE=daily
# Hour to retrain (UTC, 0-23, default 22 = 05:00 WIB)
RETRAIN_HOUR=22
# Day for weekly retrain (sun, mon, tue, wed, thu, fri, sat)
RETRAIN_DAY=sun
# Custom cron expression (only used if RETRAIN_SCHEDULE=cron): "minute hour day month day_of_week"
# Example: "0 22 * * *" = daily at 22:00, "0 22 * * 0" = weekly on Sunday at 22:00
RETRAIN_CRON=

# === INTERNAL ===
INTERNAL_API_KEY=development_key_change_in_production  # used for internal API calls between services

# === FRONTEND ===
# when running locally the engine and frontend run on different ports
NEXT_PUBLIC_STREAMER_URL=http://localhost:8080   # used by frontend to call engine
NEXT_PUBLIC_API_URL=http://localhost:3000       # base URL of Next.js app
# risk gate controls (frontend)
NEXT_PUBLIC_KILL_SWITCH_IHSG_DROP_PCT=-1.5
NEXT_PUBLIC_KILL_SWITCH_MIN_UPS=90
NEXT_PUBLIC_NORMAL_MIN_UPS=70
NEXT_PUBLIC_PARTICIPATION_CAP_NORMAL_PCT=0.01
NEXT_PUBLIC_PARTICIPATION_CAP_KILL_SWITCH_PCT=0.005
NEXT_PUBLIC_SYSTEMIC_RISK_BETA_THRESHOLD=1.5
NEXT_PUBLIC_SYSTEMIC_RISK_HARD_GATE=true
# Admin token used to authenticate protected ML engine actions.
# Prefer using an opaque token sent via `Authorization: Bearer <token>` header from the frontend.
# Set both for local dev and Vercel environment as `NEXT_PUBLIC_ADMIN_TOKEN` (frontend) and
# `ADMIN_TOKEN` (backend). Keep the backend token secret; frontend token is public to the deployed app.
NEXT_PUBLIC_ADMIN_TOKEN=change-me-next-public-admin-token
ADMIN_TOKEN=change-me-admin-token
# after deployment you will set NEXT_PUBLIC_SUPABASE_URL / ANON_KEY in Vercel

# === MARKET DATA ===
YFINANCE_ENABLED=true
GLOBAL_DATA_UPDATE_INTERVAL=300000  # 5 minutes in ms

# === LOGGING ===
LOG_LEVEL=INFO
DEBUG_MODE=false

# === TUNNEL / PUBLIC URL ===
# set by cloudflared/ngrok when you run the local engine
PUBLIC_ENGINE_URL=https://api.dellmology-idx.com/

# === SUPABASE (used by backend and frontend)
SUPABASE_URL=https://xyz.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
# Service role key (used by backend migrations and admin tasks). When set,
# the runner will apply Supabase-only SQL (policies, RLS skeletons).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Admin token used by protected ML engine endpoints. Set both `ADMIN_TOKEN`
# (backend secret) and `NEXT_PUBLIC_ADMIN_TOKEN` (frontend public token) for
# local development. Keep `ADMIN_TOKEN` secret in production.
ADMIN_TOKEN=change-me-admin-token


