# Environment Configuration for Dellmology Pro
# Copy this file to .env and fill in your values

# === GEMINI AI ===
GEMINI_API_KEY=your_gemini_api_key_here

# === DATABASE ===
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=dellmology
DATABASE_URL=postgresql://admin:password@localhost:5433/dellmology?sslmode=disable

# === STOCKBIT ===
STOCKBIT_TOKEN=your_stockbit_token_here

# === INTERNAL ===
INTERNAL_API_KEY=development_key_change_in_production

# === FRONTEND ===
NEXT_PUBLIC_STREAMER_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:3000

# === MARKET DATA ===
YFINANCE_ENABLED=true
GLOBAL_DATA_UPDATE_INTERVAL=300000  # 5 minutes in ms

# === LOGGING ===
LOG_LEVEL=INFO
DEBUG_MODE=false
